{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "desktop": {
      "command": [
        "desktop-mcp"
      ],
      "enabled": true,
      "environment": {
        "DESKTOP_RESOLUTION": "1920x1080",
        "SANDBOXED_SH_RUNTIME_WORKSPACE_FILE": "/.sandboxed-sh/runtime/current_workspace.json",
        "SANDBOXED_SH_WORKSPACE": "/workspaces/mission-dd712aff",
        "SANDBOXED_SH_WORKSPACE_ROOT": "/",
        "SANDBOXED_SH_WORKSPACE_TYPE": "host",
        "WORKING_DIR": "/workspaces/mission-dd712aff"
      },
      "type": "local"
    },
    "playwright": {
      "command": [
        "/usr/bin/npx",
        "@playwright/mcp@latest",
        "--headless",
        "--isolated",
        "--no-sandbox"
      ],
      "enabled": true,
      "environment": {
        "SANDBOXED_SH_RUNTIME_WORKSPACE_FILE": "/.sandboxed-sh/runtime/current_workspace.json",
        "SANDBOXED_SH_WORKSPACE": "/workspaces/mission-dd712aff",
        "SANDBOXED_SH_WORKSPACE_ROOT": "/",
        "SANDBOXED_SH_WORKSPACE_TYPE": "host",
        "WORKING_DIR": "/workspaces/mission-dd712aff"
      },
      "type": "local"
    },
    "workspace": {
      "command": [
        "workspace-mcp"
      ],
      "enabled": true,
      "environment": {
        "SANDBOXED_SH_RUNTIME_WORKSPACE_FILE": "/.sandboxed-sh/runtime/current_workspace.json",
        "SANDBOXED_SH_WORKSPACE": "/workspaces/mission-dd712aff",
        "SANDBOXED_SH_WORKSPACE_ROOT": "/",
        "SANDBOXED_SH_WORKSPACE_TYPE": "host",
        "WORKING_DIR": "/workspaces/mission-dd712aff"
      },
      "type": "local"
    }
  },
  "permission": {
    "bash": "allow",
    "codesearch": "allow",
    "doom_loop": "allow",
    "edit": "allow",
    "external_directory": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "question": "allow",
    "read": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "plugin": [],
  "tools": {
    "Bash": true,
    "bash": true,
    "browser_*": false,
    "desktop_*": true,
    "playwright_*": false,
    "workspace_*": false
  }
}